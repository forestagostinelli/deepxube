{
  "name": "DeepXube Codespace",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "forwardPorts": [6006],

  "portsAttributes": {
    "6006": {
      "label": "TensorBoard",
      "onAutoForward": "notify"
    }
  },

  "postAttachCommand": "deepxube --help"
}